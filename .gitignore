# === third_party (vllm + openclaw) 源码已入库，但派生产物仍需排除 ===
# 各仓库自带 .gitignore 已处理大部分，这里兜底关键产物。
# vLLM 编译产物 (*.so 运行时需要但太大不入库；*.o/.deps/build/ 中间产物)
third_party/vllm/vllm/*.so
third_party/vllm/vllm/**/*.so
third_party/vllm/vllm_flash_attn/*.so
third_party/vllm/build/
third_party/vllm/.deps/
third_party/vllm/.triton/
third_party/vllm/vllm/_version.py
# OpenClaw 构建产物 (pnpm install/build 产生，可重建)
third_party/openclaw/node_modules/
third_party/openclaw/**/node_modules/
third_party/openclaw/dist/
third_party/openclaw/dist-runtime/
third_party/openclaw/.artifacts/
third_party/openclaw/.pnpm-store/

# 通用 Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env

# XiRang 自身运行产物
runs/
.xirang_tool_store/
.benchmarks/
.pytest_cache/
*.log

# 编辑器/系统
.DS_Store
.idea/
.vscode/

# diag 原始抓包(大、可重建)，保留实验图
diag/captures/capture-*.jsonl
