{
  // 容器内 OpenClaw 配置：直连物理机 vLLM (经 host.docker.internal)
  // vLLM 跑在物理机卡3 :8001，OpenClaw 容器不经 XiRang(已删)
  models: {
    providers: {
      vllm: {
        baseUrl: "http://host.docker.internal:8001/v1",
        apiKey: "${VLLM_API_KEY}",
        api: "openai-completions",
        timeoutSeconds: 300,
        models: [
          {
            id: "Qwen3-4B",
            name: "Qwen3-4B (container -> host vLLM)",
            reasoning: true,
            compat: { thinkingFormat: "qwen-chat-template" },
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 8192,
            maxTokens: 2048,
          },
        ],
      },
    },
  },
  agents: {
    defaults: {
      model: { primary: "vllm/Qwen3-4B" },
    },
  },
}
