{
  // OpenClaw 经 tap(8002) 接 vLLM，用于抓包诊断 prefix cache 友好度
  models: {
    providers: {
      vllm: {
        baseUrl: "http://host.docker.internal:8002/v1",
        apiKey: "${VLLM_API_KEY}",
        api: "openai-completions",
        timeoutSeconds: 300,
        models: [
          {
            id: "Qwen3-4B",
            name: "Qwen3-4B (via tap)",
            reasoning: true,
            compat: { thinkingFormat: "qwen-chat-template" },
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 2048,
          },
        ],
      },
    },
  },
  agents: { defaults: { model: { primary: "vllm/Qwen3-4B" } } },
}
